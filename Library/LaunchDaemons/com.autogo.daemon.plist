<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.autogo.daemon</string>
	<key>Program</key>
	<string>/usr/bin/ios-autogo</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/ios-autogo</string>
		<string>8090</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>ThrottleInterval</key>
	<integer>3</integer>
	<key>StandardOutPath</key>
	<string>/var/mobile/Documents/autogo/logs/daemon.log</string>
	<key>StandardErrorPath</key>
	<string>/var/mobile/Documents/autogo/logs/daemon_err.log</string>
	<key>UserName</key>
	<string>root</string>
</dict>
</plist>
